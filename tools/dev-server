#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
server_host="127.0.0.1"
server_port="3210"
local_dev_dir="$repo_root/.local-dev"
server_pid_file="$local_dev_dir/thumbshooter-dev-server.pid"
shared_watch_log="$local_dev_dir/thumbshooter-dev-shared-watch.log"
server_watch_log="$local_dev_dir/thumbshooter-dev-server-watch.log"

cd "$repo_root"
mkdir -p "$local_dev_dir"

pids=()

cleanup() {
  trap - EXIT INT TERM

  if [[ -f "$server_pid_file" ]] && [[ "$(<"$server_pid_file")" == "$$" ]]; then
    rm -f "$server_pid_file"
  fi

  for pid in "${pids[@]:-}"; do
    kill "$pid" 2>/dev/null || true
  done

  wait 2>/dev/null || true
}

trap cleanup EXIT INT TERM

terminate_existing_processes() {
  local label="$1"
  shift
  local target_pids=("$@")

  if (( ${#target_pids[@]} == 0 )); then
    return 0
  fi

  echo "Stopping $label (${target_pids[*]})."

  for target_pid in "${target_pids[@]}"; do
    kill "$target_pid" 2>/dev/null || true
  done

  for target_pid in "${target_pids[@]}"; do
    for _ in {1..50}; do
      if ! kill -0 "$target_pid" 2>/dev/null; then
        break
      fi

      sleep 0.1
    done

    if kill -0 "$target_pid" 2>/dev/null; then
      echo "$label process $target_pid did not exit cleanly."
      exit 1
    fi
  done
}

started_watch_pid=""

start_watch_build() {
  local log_file="$1"
  shift

  : > "$log_file"

  "$@" > >(tee "$log_file") 2>&1 &
  started_watch_pid="$!"
  pids+=("$started_watch_pid")
}

wait_for_watch_build_ready() {
  local label="$1"
  local log_file="$2"
  local watch_pid="$3"

  while true; do
    if [[ -f "$log_file" ]]; then
      if grep -Eq 'Found 0 errors?\. Watching for file changes\.' "$log_file"; then
        return 0
      fi

      if grep -Eq 'Found [1-9][0-9]* errors?\. Watching for file changes\.' "$log_file"; then
        echo "ThumbShooter $label watch build reported errors during startup."
        return 1
      fi
    fi

    if ! kill -0 "$watch_pid" 2>/dev/null; then
      echo "ThumbShooter $label watch build exited before startup completed."
      return 1
    fi

    sleep 0.1
  done
}

resolve_existing_dev_server_pid() {
  if [[ ! -f "$server_pid_file" ]]; then
    return 1
  fi

  local existing_pid
  existing_pid="$(<"$server_pid_file")"

  if [[ ! "$existing_pid" =~ ^[0-9]+$ ]]; then
    rm -f "$server_pid_file"
    return 1
  fi

  if ! kill -0 "$existing_pid" 2>/dev/null; then
    rm -f "$server_pid_file"
    return 1
  fi

  local existing_args
  existing_args="$(ps -p "$existing_pid" -o args= 2>/dev/null || true)"

  if [[ "$existing_args" != *"tools/dev-server"* ]]; then
    rm -f "$server_pid_file"
    return 1
  fi

  printf '%s\n' "$existing_pid"
}

resolve_existing_managed_server_watch_pid() {
  while read -r process_pid process_args; do
    if [[ -z "$process_pid" ]]; then
      continue
    fi

    if [[ "$process_args" != *"$repo_root/server/dist/index.js"* ]]; then
      continue
    fi

    if [[ "$process_args" != *"--watch-path $repo_root/packages/shared/dist"* ]]; then
      continue
    fi

    if [[ "$process_args" != *"--watch-path $repo_root/server/dist"* ]]; then
      continue
    fi

    printf '%s\n' "$process_pid"
    return 0
  done < <(ps -eo pid=,args=)

  return 1
}

resolve_existing_repo_server_runtime_pids() {
  while read -r process_pid process_args; do
    if [[ -z "$process_pid" ]]; then
      continue
    fi

    if [[ "$process_args" != *"$repo_root/server/dist/index.js"* ]]; then
      continue
    fi

    printf '%s\n' "$process_pid"
  done < <(ps -eo pid=,args=)
}

resolve_existing_repo_watch_build_pids() {
  while read -r process_pid process_args; do
    if [[ -z "$process_pid" ]]; then
      continue
    fi

    if [[ "$process_args" != *"$repo_root/node_modules/.bin/tsc"* ]]; then
      continue
    fi

    if [[ "$process_args" != *"--watch"* ]]; then
      continue
    fi

    if [[ "$process_args" != *"--preserveWatchOutput"* ]]; then
      continue
    fi

    printf '%s\n' "$process_pid"
  done < <(ps -eo pid=,args=)
}

resolve_existing_repo_watch_log_pids() {
  while read -r process_pid process_args; do
    if [[ -z "$process_pid" ]]; then
      continue
    fi

    if [[ "$process_args" == *"tee $shared_watch_log"* ]] || [[ "$process_args" == *"tee $server_watch_log"* ]]; then
      printf '%s\n' "$process_pid"
    fi
  done < <(ps -eo pid=,args=)
}

existing_dev_server_pid="$(resolve_existing_dev_server_pid || true)"

if [[ -n "$existing_dev_server_pid" ]]; then
  terminate_existing_processes \
    "existing ThumbShooter dev server session" \
    "$existing_dev_server_pid"
fi

existing_server_watch_pid="$(resolve_existing_managed_server_watch_pid || true)"

if [[ -n "$existing_server_watch_pid" ]]; then
  terminate_existing_processes \
    "existing ThumbShooter managed server watcher" \
    "$existing_server_watch_pid"
fi

mapfile -t existing_repo_server_runtime_pids < <(
  resolve_existing_repo_server_runtime_pids | sort -u || true
)

terminate_existing_processes \
  "existing ThumbShooter server runtime" \
  "${existing_repo_server_runtime_pids[@]}"

mapfile -t existing_repo_watch_build_pids < <(
  resolve_existing_repo_watch_build_pids | sort -u || true
)

terminate_existing_processes \
  "existing ThumbShooter TypeScript watch builds" \
  "${existing_repo_watch_build_pids[@]}"

mapfile -t existing_repo_watch_log_pids < <(
  resolve_existing_repo_watch_log_pids | sort -u || true
)

terminate_existing_processes \
  "existing ThumbShooter dev watch log relays" \
  "${existing_repo_watch_log_pids[@]}"

printf '%s\n' "$$" > "$server_pid_file"

# Fail fast when another process already owns the locked local co-op port.
node \
  --input-type=module \
  --eval '
    import { createServer } from "node:net";

    const host = process.argv[1];
    const port = Number(process.argv[2]);

    const server = createServer();

    server.once("error", (error) => {
      if ("code" in error && error.code === "EADDRINUSE") {
        console.error(
          `ThumbShooter dev server could not start because http://${host}:${port} is already in use. Stop the existing server process or run \`npm run dev:client\` if you only need the metaverse shell.`
        );
        process.exit(1);
      }

      throw error;
    });

    server.listen(port, host, () => {
      server.close(() => {
        process.exit(0);
      });
    });
  ' \
  "$server_host" \
  "$server_port"

# Avoid the workspace build scripts here because they aggressively clean `dist/`
# trees. Cleaning during dev startup can race an already-running watcher and
# temporarily remove package outputs that the server process imports.
./node_modules/.bin/tsc -p "$repo_root/packages/shared/tsconfig.json"
./node_modules/.bin/tsc -p "$repo_root/server/tsconfig.json"

start_watch_build \
  "$shared_watch_log" \
  npm run watch:build --workspace @thumbshooter/shared
shared_watch_pid="$started_watch_pid"

start_watch_build \
  "$server_watch_log" \
  npm run watch:build --workspace @thumbshooter/server
server_watch_pid="$started_watch_pid"

wait_for_watch_build_ready "shared" "$shared_watch_log" "$shared_watch_pid"
wait_for_watch_build_ready "server" "$server_watch_log" "$server_watch_pid"

echo "ThumbShooter dev watch builds are ready. Starting server runtime."

node \
  --watch \
  --watch-preserve-output \
  --watch-path "$repo_root/packages/shared/dist" \
  --watch-path "$repo_root/server/dist" \
  "$repo_root/server/dist/index.js" &
pids+=($!)

wait -n "${pids[@]}"
