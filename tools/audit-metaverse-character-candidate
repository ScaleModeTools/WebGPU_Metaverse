#!/usr/bin/env node

import { readFileSync } from "node:fs";
import path from "node:path";

const skeletonConfigs = Object.freeze({
  humanoid_v2: Object.freeze({
    boneParentByName: Object.freeze({
      root: null,
      pelvis: "root",
      spine_01: "pelvis",
      spine_02: "spine_01",
      spine_03: "spine_02",
      neck_01: "spine_03",
      head: "neck_01",
      clavicle_l: "spine_03",
      upperarm_l: "clavicle_l",
      lowerarm_l: "upperarm_l",
      hand_l: "lowerarm_l",
      clavicle_r: "spine_03",
      upperarm_r: "clavicle_r",
      lowerarm_r: "upperarm_r",
      hand_r: "lowerarm_r",
      thigh_l: "pelvis",
      calf_l: "thigh_l",
      foot_l: "calf_l",
      ball_l: "foot_l",
      thigh_r: "pelvis",
      calf_r: "thigh_r",
      foot_r: "calf_r",
      ball_r: "foot_r"
    }),
    compareReferenceAnimationPack: false,
    referenceAnimationPackPath: null,
    referenceRenderPath: null,
    requiredBoneNames: Object.freeze([
      "root",
      "pelvis",
      "spine_01",
      "spine_02",
      "spine_03",
      "neck_01",
      "head",
      "clavicle_l",
      "upperarm_l",
      "lowerarm_l",
      "hand_l",
      "clavicle_r",
      "upperarm_r",
      "lowerarm_r",
      "hand_r",
      "thigh_l",
      "calf_l",
      "foot_l",
      "ball_l",
      "thigh_r",
      "calf_r",
      "foot_r",
      "ball_r"
    ]),
    socketParentById: Object.freeze({
      hand_r_socket: "hand_r",
      hand_l_socket: "hand_l",
      head_socket: "head",
      hip_socket: "pelvis",
      seat_socket: "pelvis"
    })
  })
});

const supportedSkeletonIds = Object.freeze(Object.keys(skeletonConfigs));
const canonicalSocketIds = Object.freeze([
  "hand_r_socket",
  "hand_l_socket",
  "head_socket",
  "hip_socket",
  "seat_socket"
]);
const transformTolerance = 0.0001;

function usage() {
  console.error(
    `Usage: ./tools/audit-metaverse-character-candidate [--skeleton=${supportedSkeletonIds.join("|")}] <path-to-.glb-or-.gltf>`
  );
}

function parseArguments(argv) {
  let skeletonId = "humanoid_v2";
  let candidatePathArgument = null;

  for (const argument of argv) {
    if (argument.startsWith("--skeleton=")) {
      skeletonId = argument.slice("--skeleton=".length);
      continue;
    }

    if (candidatePathArgument !== null) {
      throw new Error(`Unexpected extra argument: ${argument}`);
    }

    candidatePathArgument = argument;
  }

  if (!(skeletonId in skeletonConfigs)) {
    throw new Error(
      `Unsupported skeleton ${skeletonId}. Expected one of: ${supportedSkeletonIds.join(", ")}.`
    );
  }

  if (candidatePathArgument === null) {
    usage();
    process.exit(1);
  }

  return {
    candidatePathArgument,
    skeletonId
  };
}

function parseGlbDocument(filePath) {
  const bytes = readFileSync(filePath);
  const magic = bytes.subarray(0, 4).toString("utf8");

  if (magic !== "glTF") {
    throw new Error(`${filePath} is not a valid GLB file.`);
  }

  const jsonChunkLength = bytes.readUInt32LE(12);
  const jsonChunkType = bytes.readUInt32LE(16);

  if (jsonChunkType !== 0x4e4f534a) {
    throw new Error(`${filePath} does not contain a JSON chunk in the expected location.`);
  }

  return JSON.parse(bytes.subarray(20, 20 + jsonChunkLength).toString("utf8").trim());
}

function loadAssetDocument(filePath) {
  if (filePath.endsWith(".glb")) {
    return parseGlbDocument(filePath);
  }

  if (filePath.endsWith(".gltf")) {
    return JSON.parse(readFileSync(filePath, "utf8"));
  }

  throw new Error(`${filePath} must be a .glb or .gltf asset.`);
}

function collectNamedNodes(document) {
  return new Map(
    (document.nodes ?? [])
      .map((node) => {
        if (typeof node.name !== "string") {
          return null;
        }

        return [
          node.name,
          {
            children: node.children ?? [],
            rotation: node.rotation ?? [0, 0, 0, 1],
            scale: node.scale ?? null,
            translation: node.translation ?? [0, 0, 0]
          }
        ];
      })
      .filter((entry) => entry !== null)
  );
}

function collectParentNameByNodeName(document) {
  const parentNameByNodeName = new Map();

  for (const node of document.nodes ?? []) {
    if (typeof node.name !== "string") {
      continue;
    }

    for (const childIndex of node.children ?? []) {
      const childName = document.nodes?.[childIndex]?.name;

      if (typeof childName === "string") {
        parentNameByNodeName.set(childName, node.name);
      }
    }
  }

  return parentNameByNodeName;
}

function resolveNamedCanonicalChildren(document, childIndices, canonicalNames) {
  return (childIndices ?? [])
    .map((childIndex) => document.nodes?.[childIndex]?.name)
    .filter((childName) => typeof childName === "string" && canonicalNames.has(childName));
}

function maxDirectDelta(actual, expected) {
  let maxDelta = 0;

  for (let index = 0; index < actual.length; index += 1) {
    maxDelta = Math.max(maxDelta, Math.abs(actual[index] - expected[index]));
  }

  return maxDelta;
}

function quaternionDelta(actual, expected) {
  let maxDelta = 0;
  let maxNegatedDelta = 0;

  for (let index = 0; index < actual.length; index += 1) {
    maxDelta = Math.max(maxDelta, Math.abs(actual[index] - expected[index]));
    maxNegatedDelta = Math.max(maxNegatedDelta, Math.abs(actual[index] + expected[index]));
  }

  return Math.min(maxDelta, maxNegatedDelta);
}

function formatArray(values) {
  return `[${values.map((value) => Number(value).toFixed(6)).join(", ")}]`;
}

function collectSceneRootNames(document) {
  return (document.scenes?.[document.scene ?? 0]?.nodes ?? [])
    .map((nodeIndex) => document.nodes?.[nodeIndex]?.name)
    .filter((name) => typeof name === "string");
}

function collectTransformProblems({
  candidateDocument,
  candidateNodesByName,
  candidateParentNameByNodeName,
  canonicalNames,
  referenceAnimationPackDocument,
  skeletonConfig
}) {
  const transformProblems = [];

  for (const canonicalName of [
    ...skeletonConfig.requiredBoneNames,
    ...canonicalSocketIds
  ]) {
    const candidateNode = candidateNodesByName.get(canonicalName);

    if (candidateNode === undefined) {
      continue;
    }

    const expectedParent =
      skeletonConfig.boneParentByName[canonicalName] ??
      skeletonConfig.socketParentById[canonicalName] ??
      null;
    const rawParentName = candidateParentNameByNodeName.get(canonicalName) ?? null;
    const canonicalParentName = canonicalNames.has(rawParentName) ? rawParentName : null;

    if (canonicalParentName !== expectedParent) {
      transformProblems.push(
        `${canonicalName}: expected canonical parent ${String(expectedParent)}, received ${String(canonicalParentName)}`
      );
    }

    if (referenceAnimationPackDocument === null) {
      continue;
    }

    const referenceNodesByName = collectNamedNodes(referenceAnimationPackDocument);
    const referenceNode = referenceNodesByName.get(canonicalName);

    if (referenceNode === undefined) {
      continue;
    }

    const translationDelta = maxDirectDelta(
      candidateNode.translation,
      referenceNode.translation
    );

    if (translationDelta > transformTolerance) {
      transformProblems.push(
        `${canonicalName}: translation drift ${translationDelta.toFixed(6)} candidate=${formatArray(candidateNode.translation)} reference=${formatArray(referenceNode.translation)}`
      );
    }

    const rotationDelta = quaternionDelta(candidateNode.rotation, referenceNode.rotation);

    if (rotationDelta > transformTolerance) {
      transformProblems.push(
        `${canonicalName}: rotation drift ${rotationDelta.toFixed(6)} candidate=${formatArray(candidateNode.rotation)} reference=${formatArray(referenceNode.rotation)}`
      );
    }

    const candidateChildren = resolveNamedCanonicalChildren(
      candidateDocument,
      candidateNode.children,
      canonicalNames
    );
    const referenceChildren = resolveNamedCanonicalChildren(
      referenceAnimationPackDocument,
      referenceNode.children,
      canonicalNames
    );

    if (
      candidateChildren.length !== referenceChildren.length ||
      candidateChildren.some((childName, index) => childName !== referenceChildren[index])
    ) {
      transformProblems.push(
        `${canonicalName}: canonical child ordering mismatch candidate=${JSON.stringify(candidateChildren)} reference=${JSON.stringify(referenceChildren)}`
      );
    }
  }

  return transformProblems;
}

const { candidatePathArgument, skeletonId } = parseArguments(process.argv.slice(2));
const repoRoot = process.cwd();
const skeletonConfig = skeletonConfigs[skeletonId];
const canonicalNames = new Set([
  ...skeletonConfig.requiredBoneNames,
  ...canonicalSocketIds
]);
const candidatePath = path.resolve(repoRoot, candidatePathArgument);
const referenceRenderPath =
  skeletonConfig.referenceRenderPath === null
    ? null
    : path.join(repoRoot, skeletonConfig.referenceRenderPath);
const referenceAnimationPackPath =
  skeletonConfig.referenceAnimationPackPath === null
    ? null
    : path.join(repoRoot, skeletonConfig.referenceAnimationPackPath);
const candidateDocument = loadAssetDocument(candidatePath);
const referenceRenderDocument =
  referenceRenderPath === null ? null : loadAssetDocument(referenceRenderPath);
const referenceAnimationPackDocument =
  referenceAnimationPackPath === null ? null : loadAssetDocument(referenceAnimationPackPath);
const candidateNodesByName = collectNamedNodes(candidateDocument);
const candidateParentNameByNodeName = collectParentNameByNodeName(candidateDocument);
const nodeScaleNames = [...candidateNodesByName.entries()]
  .filter(([, node]) => node.scale !== null)
  .map(([name]) => name);
const animationNames = (candidateDocument.animations ?? [])
  .map((animation) => animation.name)
  .filter((name) => typeof name === "string");
const missingCanonicalBones = skeletonConfig.requiredBoneNames.filter(
  (name) => !candidateNodesByName.has(name)
);
const missingCanonicalSockets = canonicalSocketIds.filter(
  (name) => !candidateNodesByName.has(name)
);
const transformProblems = collectTransformProblems({
  candidateDocument,
  candidateNodesByName,
  candidateParentNameByNodeName,
  canonicalNames,
  referenceAnimationPackDocument: skeletonConfig.compareReferenceAnimationPack
    ? referenceAnimationPackDocument
    : null,
  skeletonConfig
});
const candidateRootNames = collectSceneRootNames(candidateDocument);
const referenceRootNames =
  referenceRenderDocument === null ? [] : collectSceneRootNames(referenceRenderDocument);
const passes =
  missingCanonicalBones.length === 0 &&
  missingCanonicalSockets.length === 0 &&
  nodeScaleNames.length === 0 &&
  transformProblems.length === 0;

console.log("# Metaverse Character Candidate Audit");
console.log("");
console.log(`- candidate: \`${path.relative(repoRoot, candidatePath)}\``);
console.log(`- skeleton: \`${skeletonId}\``);
console.log(`- scenes: ${(candidateDocument.scenes ?? []).length}`);
console.log(`- nodes: ${(candidateDocument.nodes ?? []).length}`);
console.log(`- skins: ${(candidateDocument.skins ?? []).length}`);
console.log(`- meshes: ${(candidateDocument.meshes ?? []).length}`);
console.log(`- materials: ${(candidateDocument.materials ?? []).length}`);
console.log(`- animations: ${animationNames.length}`);
console.log(`- candidate scene roots: ${candidateRootNames.join(", ") || "(none)"}`);

if (referenceRootNames.length > 0) {
  console.log(`- reference scene roots: ${referenceRootNames.join(", ")}`);
}

console.log("");
console.log("## Animation Names");
console.log("");

for (const animationName of animationNames) {
  console.log(`- ${animationName}`);
}

if (animationNames.length === 0) {
  console.log("- (none)");
}

console.log("");
console.log("## Canonical Rig Gaps");
console.log("");
console.log(
  `- missing canonical bones: ${missingCanonicalBones.length === 0 ? "(none)" : missingCanonicalBones.join(", ")}`
);
console.log(
  `- missing canonical sockets: ${missingCanonicalSockets.length === 0 ? "(none)" : missingCanonicalSockets.join(", ")}`
);
console.log(
  `- nodes with explicit scale transforms: ${nodeScaleNames.length === 0 ? "(none)" : nodeScaleNames.join(", ")}`
);
console.log("");
console.log("## Compatibility Problems");
console.log("");

if (transformProblems.length === 0) {
  console.log("- (none)");
} else {
  for (const problem of transformProblems) {
    console.log(`- ${problem}`);
  }
}

console.log("");
console.log("## Verdict");
console.log("");
console.log(
  passes
    ? `- PASS: candidate matches the ${skeletonId} repo rig gate.`
    : `- FAIL: candidate does not match the ${skeletonId} repo rig gate. Keep it outside shipped manifests until it is externally conditioned.`
);
