    "@thumbshooter/shared": "0.1.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.7.0",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "4.1.2",
    "tailwind-merge": "3.5.0",
    "three": "0.183.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.183.0",
    "@vitejs/plugin-react": "6.0.1",
