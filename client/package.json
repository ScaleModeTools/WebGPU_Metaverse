{
  "name": "@thumbshooter/client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "node --input-type=module --eval \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\"",
    "dev": "vite",
    "build": "npm run clean && tsc -p tsconfig.json --noEmit && vite build",
