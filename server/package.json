{
  "name": "@thumbshooter/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "node --input-type=module --eval \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "watch:build": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "start": "node dist/index.js",
    "start:watch": "node --watch --watch-path dist dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
