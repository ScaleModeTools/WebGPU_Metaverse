{
  "name": "@webgpu-metaverse/shared",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./metaverse": {
      "types": "./dist/metaverse/index.d.ts",
      "import": "./dist/metaverse/index.js",
      "default": "./dist/metaverse/index.js"
    },
    "./metaverse/traversal": {
      "types": "./dist/metaverse/traversal/index.d.ts",
      "import": "./dist/metaverse/traversal/index.js",
      "default": "./dist/metaverse/traversal/index.js"
    },
    "./metaverse/world": {
      "types": "./dist/metaverse/world/index.d.ts",
      "import": "./dist/metaverse/world/index.js",
      "default": "./dist/metaverse/world/index.js"
    },
    "./metaverse/presence": {
      "types": "./dist/metaverse/presence/index.d.ts",
      "import": "./dist/metaverse/presence/index.js",
      "default": "./dist/metaverse/presence/index.js"
    },
    "./metaverse/realtime": {
      "types": "./dist/metaverse/realtime/index.d.ts",
      "import": "./dist/metaverse/realtime/index.js",
      "default": "./dist/metaverse/realtime/index.js"
    },
    "./metaverse/session": {
      "types": "./dist/metaverse/session/index.d.ts",
      "import": "./dist/metaverse/session/index.js",
      "default": "./dist/metaverse/session/index.js"
    },
    "./metaverse/portal": {
      "types": "./dist/metaverse/portal/index.d.ts",
      "import": "./dist/metaverse/portal/index.js",
      "default": "./dist/metaverse/portal/index.js"
    },
    "./experiences": {
      "types": "./dist/experiences/index.d.ts",
      "import": "./dist/experiences/index.js",
      "default": "./dist/experiences/index.js"
    },
    "./experiences/duck-hunt": {
      "types": "./dist/experiences/duck-hunt/index.d.ts",
      "import": "./dist/experiences/duck-hunt/index.js",
      "default": "./dist/experiences/duck-hunt/index.js"
    }
  },
  "scripts": {
    "clean": "node --input-type=module --eval \"import { rmSync, readdirSync } from 'node:fs'; import { join } from 'node:path'; rmSync('dist', { recursive: true, force: true }); const removeGeneratedSourceArtifacts = (rootPath) => { for (const entry of readdirSync(rootPath, { withFileTypes: true })) { const absolutePath = join(rootPath, entry.name); if (entry.isDirectory()) { removeGeneratedSourceArtifacts(absolutePath); continue; } if (/\\.(?:d\\.ts|d\\.ts\\.map|js|js\\.map)$/.test(entry.name)) { rmSync(absolutePath, { force: true }); } } }; removeGeneratedSourceArtifacts('src');\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "watch:build": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
